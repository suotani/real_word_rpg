<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-brand-icon">⚔️</div>
      <h1 class="auth-brand-name">ホームラボ</h1>
    </div>

    <h2 class="auth-title">新規登録</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-field">
        <%= f.label :email, "メールアドレス", class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, class: "auth-input", placeholder: "example@email.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :name, "アカウント名", class: "auth-label" %>
        <%= f.text_field :name, class: "auth-input", placeholder: "冒険者の名前" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "パスワード", class: "auth-label" %>
        <% if @minimum_password_length %>
          <span class="auth-hint"><%= @minimum_password_length %>文字以上</span>
        <% end %>
        <%= f.password_field :password, class: "auth-input", placeholder: "••••••••" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "auth-label" %>
        <%= f.password_field :password_confirmation, class: "auth-input", placeholder: "••••••••" %>
      </div>

      <%= f.submit "登録する", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      <span class="auth-links-text">すでにアカウントをお持ちの方は</span>
      <%= link_to "ログイン", new_session_path(resource_name), class: "auth-link" %>
    </div>
  </div>
</div>

<style>
  body { background: #f5f0e8; }

  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .auth-card {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }

  .auth-brand {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth-brand-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }

  .auth-brand-name {
    font-size: 1.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, #ff6b35 0%, #ffa244 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
  }

  .auth-brand-sub { color: #999; font-size: 0.85rem; margin: 0.25rem 0 0; }

  .auth-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .auth-field { margin-bottom: 1.1rem; position: relative; }

  .auth-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    margin-bottom: 0.4rem;
  }

  .auth-hint {
    font-size: 0.75rem;
    color: #aaa;
    margin-left: 0.4rem;
  }

  .auth-input {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 2px solid #e9ecef;
    border-radius: 10px;
    font-size: 0.95rem;
    transition: border-color 0.2s;
    outline: none;
    box-sizing: border-box;
  }

  .auth-input:focus { border-color: #ffa244; }

  .auth-btn {
    width: 100%;
    padding: 0.8rem;
    background: linear-gradient(135deg, #ff6b35 0%, #ffa244 100%);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }

  .auth-btn:hover { opacity: 0.9; transform: translateY(-1px); }

  .auth-links {
    margin-top: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .auth-links-text { font-size: 0.85rem; color: #888; }

  .auth-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: #ff6b35;
    text-decoration: none;
  }

  .auth-link:hover { text-decoration: underline; }
</style>
