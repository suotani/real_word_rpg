<% if resource.errors.any? %>
  <div class="auth-errors">
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>

  <style>
    .auth-errors {
      background: #fff5f5;
      border: 1.5px solid #fc8181;
      border-radius: 10px;
      padding: 0.8rem 1rem;
      margin-bottom: 1.2rem;
      font-size: 0.85rem;
      color: #c53030;
    }
    .auth-errors ul {
      margin: 0;
      padding-left: 1.2rem;
    }
    .auth-errors li { margin-bottom: 0.2rem; }
    .auth-errors li:last-child { margin-bottom: 0; }
  </style>
<% end %>
