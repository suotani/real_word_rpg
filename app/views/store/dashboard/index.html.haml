.store-dashboard-container
  - if @current_town
    .card.shadow-sm.border-0.mb-4.px-4.py-3.d-flex.flex-row.align-items-center.justify-content-between.flex-wrap.gap-2
      .d-flex.align-items-center.gap-2
        %i.fas.fa-map-marker-alt.text-primary
        %span.fw-bold= @current_town.name
      .d-flex.align-items-center.gap-2
        %span.text-muted.small 参加パスワード:
        %code.bg-light.px-2.py-1.rounded= @current_town.password

  .row.g-3.mb-4
    .col-sm-4
      .card.shadow-sm.border-0.text-center.py-3
        .text-muted.small 所持金
        .fs-4.fw-bold= "#{number_with_delimiter(current_user.balance)}円"
    .col-sm-4
      .card.shadow-sm.border-0.text-center.py-3
        .text-muted.small 借入残高
        - if current_user.in_debt?
          .fs-4.fw-bold.text-danger= "#{number_with_delimiter(current_user.loan_amount)}円"
          .small.text-muted= "残枠 #{number_with_delimiter(current_user.remaining_loan_capacity)}円"
        - else
          .fs-4.fw-bold.text-muted 0円
    .col-sm-4
      .card.shadow-sm.border-0.text-center.py-3
        .text-muted.small 在庫数
        .fs-4.fw-bold= "#{@total_stock_count}件"
        .small.text-muted= "出品中 #{@listed_stock_count}件"

  - if @current_town
    .towns-section
      %h2
        = @current_town.name
        %small.text-muted.fs-6.ms-2 自分のお店

      - if @user_stores.any?
        .stores-list
          - @user_stores.each do |store|
            .store-item
              .store-info
                %h4.store-name
                  = link_to store.name, store_store_path(store), class: "text-decoration-none text-dark"
                %p.store-category #{store.store_category&.name || '未分類'}
                - hours = store.store_category&.buisiness_times&.map(&:sales_at)&.sort&.uniq || []
                - if hours.any?
                  %p.store-stock
                    %i.fas.fa-clock.me-1
                    = hours.map { |h| "#{h}時" }.join(', ')
                - else
                  %p.store-stock.empty 購入時間帯 未設定
                - if store.stocks.any?
                  %p.store-stock 在庫: #{store.stocks.count}アイテム
                - else
                  %p.store-stock.empty 在庫なし
              .store-actions
                = link_to store_store_path(store), class: "btn btn-outline-primary btn-sm" do
                  %span 詳細
                = link_to store_store_stocks_path(store), class: "btn btn-primary btn-sm" do
                  %span 在庫を見る
      - else
        .no-stores
          %p この町にはまだ店舗がありません
          = link_to new_store_store_path, class: "btn btn-success" do
            %span 店舗を開設
  - else
    .empty-state
      %h3 町を選択してください
      %p 参加している町を選択するか、新しい町に進出しましょう。

      .d-flex.justify-content-center
        = link_to join_request_store_towns_path, class: "btn btn-outline-primary m-3" do
          %h3 町に参加
        = link_to new_store_town_path, class: "btn btn-outline-info m-3" do
          %h3 町を作る


:css
  .store-dashboard-container {
    padding: 2rem;
    min-height: 100vh;
  }

  .dashboard-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .towns-section {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 3rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .towns-section h2 {
    margin: 0 0 2rem 0;
    color: #333;
    font-size: 1.8rem;
  }

  .stores-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .store-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 10px;
    transition: background 0.2s;
  }

  .store-item:hover {
    background: #e9ecef;
  }

  .store-name {
    margin: 0 0 0.25rem 0;
    font-size: 1.1rem;
    color: #333;
  }

  .store-category {
    margin: 0 0 0.25rem 0;
    color: #666;
    font-size: 0.9rem;
  }

  .store-stock {
    margin: 0;
    font-size: 0.8rem;
    color: #28a745;
  }

  .store-stock.empty {
    color: #dc3545;
  }

  .store-actions {
    display: flex;
    gap: 0.5rem;
  }

  .no-stores {
    text-align: center;
    padding: 2rem;
    color: #666;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: #666;
  }
