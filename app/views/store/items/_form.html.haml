-# 商品登録・編集フォームの共通部分（form は呼び出し元で form_with のブロック変数）
- if @item.errors.any?
  .alert.alert-danger
    %h5= t('activerecord.errors.template.header', count: @item.errors.count)
    %ul
      - @item.errors.full_messages.each do |message|
        %li= message

.row.mb-4
  .col-md-8
    .form-group
      = form.label :name, "商品名", class: "form-label font-weight-bold"
      = form.text_field :name, class: "form-control form-control-lg", placeholder: "商品名を入力してください"
  
  .col-md-4
    .form-group
      = form.label :item_category_id, "カテゴリー", class: "form-label font-weight-bold"
      = form.select :item_category_id, options_from_collection_for_select(@item_categories, :id, :name, @item.item_category_id), { class: "form-control form-control-lg" }

%hr.my-4
%h5.mb-3
  %i.fas.fa-list-ul
  必要な材料（自分の在庫から選択）
- if @stock_items.any?
  #recipe-materials
    = form.fields_for :recipe_materials do |mf|
      .form-group.row.align-items-end.recipe-material-row.mb-4
        .col-md-7
          = mf.select :item_id, options_from_collection_for_select(@stock_items, :id, :name, mf.object.item_id), { include_blank: "選択してください" }, class: "form-control"
        .col-md-2
          - if mf.object.persisted?
            = mf.check_box :_destroy, class: "form-check-input"
            = mf.label :_destroy, "削除", class: "form-check-label small"
          - else
            = mf.hidden_field :_destroy
  %p.form-text.text-muted.small 「削除」にチェックで行を削除できます。
- else
  .alert.alert-info
    %i.fas.fa-info-circle
    在庫がありません。先に店舗で在庫を登録してください。

%hr.my-4

.d-flex.justify-content-between
  - if @item.persisted?
    = link_to store_store_item_path(@store, @item), class: "btn btn-outline-secondary btn-lg" do
      %i.fas.fa-arrow-left
      キャンセル
    = form.submit "商品を更新", class: "btn btn-warning btn-lg"
  - else
    = link_to store_store_items_path(@store), class: "btn btn-outline-secondary btn-lg" do
      %i.fas.fa-arrow-left
      キャンセル
    = form.submit "商品を登録", class: "btn btn-primary btn-lg"
