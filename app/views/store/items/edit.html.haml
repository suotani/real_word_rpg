.container
  .row.justify-content-center
    .col-lg-8
      / パンくずリスト
      %nav{aria: {label: "breadcrumb"}}
        %ol.breadcrumb
          %li.breadcrumb-item
            = link_to "商品一覧", store_store_items_path(@store)
          %li.breadcrumb-item
            = link_to @item.name, store_store_item_path(@store, @item)
          %li.breadcrumb-item.active{aria: {current: "page"}} 編集

      .card.shadow
        .card-header.bg-warning.text-dark
          %h4.mb-0
            %i.fas.fa-edit
            商品編集
        .card-body
          = form_with model: @item, url: store_store_item_path(@store, @item), method: :patch, local: true do |form|
            = render 'form', form: form
