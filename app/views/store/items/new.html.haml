.container
  .row.justify-content-center
    .col-lg-8
      .card.shadow
        .card-header.bg-primary.text-white
          %h4.mb-0
            %i.fas.fa-plus
            商品開発
        .card-body
          = form_with model: @item, url: store_store_items_path(@store), local: true do |form|
            = render 'form', form: form
