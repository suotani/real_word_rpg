.container.py-4
  .row.justify-content-center
    .col-lg-6.col-md-8

      .d-flex.align-items-center.gap-3.mb-4
        = link_to store_store_path(@store), class: 'btn btn-outline-secondary btn-sm' do
          %i.fas.fa-arrow-left
          戻る
        %h1.mb-0 お店を編集する

      .card.shadow-sm
        .card-body.p-4
          = form_with model: [:store, @store], local: true do |f|
            - if @store.errors.any?
              .alert.alert-danger
                %ul.mb-0
                  - @store.errors.full_messages.each do |msg|
                    %li= msg

            .mb-3
              = f.label :name, 'お店の名前', class: 'form-label fw-bold'
              = f.text_field :name, class: 'form-control'

            .mb-3
              = f.label :store_category_id, 'カテゴリ', class: 'form-label fw-bold'
              = f.select :store_category_id,
                  @store_categories.map { |sc| [sc.name, sc.id] },
                  {},
                  { class: 'form-select' }

            .mb-3
              = f.label :theme_color, 'テーマカラー', class: 'form-label fw-bold'
              = f.color_field :theme_color, class: 'form-control form-control-color'

            .mb-4
              = f.label :theme_sub_color, 'サブカラー', class: 'form-label fw-bold'
              = f.color_field :theme_sub_color, class: 'form-control form-control-color'

            = f.submit '更新する', class: 'btn btn-primary w-100'
