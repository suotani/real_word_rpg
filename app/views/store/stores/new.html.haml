.container-fluid.bg-light.min-vh-100.py-4
  .row.justify-content-center
    .col-lg-8.col-md-10.col-12
      .card.shadow-lg.border-0.mb-4
        .card-body.text-center.py-5
          %h1.display-4.text-primary.fw-bold 新しいお店を始めよう

      .card.shadow-lg.border-0.mb-4
        .card-body.p-4
          - if flash[:alert]
            .alert.alert-danger.alert-dismissible.fade.show
              %p.mb-0 #{flash[:alert]}
              %button.btn-close{"data-bs-dismiss" => "alert"}
          
          = form_with model: @store, url: store_stores_path, local: true, class: "needs-validation", novalidate: true do |form|
            .mb-4
              = form.label :name, "お店の名前", class: "form-label"
              = form.text_field :name, class: "form-control", placeholder: "例: 美味しいパン屋、便利なコンビニ、おしゃれなカフェ", required: true
            
            .mb-4
              = form.label :store_category_id, "どんなお店ですか？", class: "form-label", for: "store_category_select"
              = form.select :store_category_id,
                  @store_categories.map { |sc| [sc.name, sc.id, { 'data-listing-fee': sc.listing_fee }] },
                  { prompt: "カテゴリを選択してください" },
                  { class: "form-control", required: true, id: "store_category_select" }
              .mt-2.d-flex.align-items-center.gap-2
                %i.fas.fa-coins.text-warning
                %span.small.text-muted 出店料:
                %span#listing-fee-display.fw-bold.text-muted —
              .mt-1.small.text-muted
                現在の所持金:
                %span.fw-bold= "#{current_user.balance}円"
            
            .mb-4
              = form.label :theme_color, "テーマカラー", class: "form-label"
              = form.color_field :theme_color, class: "form-control form-control-color", value: "#FF6B35", title: "お店のメインカラーを選択してください"
              %p クリックで色を変えることができます。
            
            .mb-4
              = form.label :theme_sub_color, "サブカラー", class: "form-label"
              = form.color_field :theme_sub_color, class: "form-control form-control-color", value: "#F7931E", title: "お店のサブカラーを選択してください"
              %p クリックで色を変えることができます。

            .d-flex.justify-content-center.gap-3
              = form.submit "決定", class: "btn btn-primary btn-lg px-4 mx-3"
              = link_to "やめる", store_dashboard_path, class: "btn btn-secondary btn-lg px-4"


:javascript
  document.addEventListener('DOMContentLoaded', function() {
    var select  = document.getElementById('store_category_select');
    var display = document.getElementById('listing-fee-display');
    select.addEventListener('change', function() {
      var option = select.options[select.selectedIndex];
      var fee    = option.dataset.listingFee;
      display.textContent = fee ? Number(fee).toLocaleString() + '円' : '—';
    });
  });

:css
  .text-primary {
    background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  } 