- color     = @store.theme_color
- sub_color = @store.theme_sub_color

.col-lg-8.col-md-10.mx-auto.py-4

  / ヒーローバナー（店名を重ねて表示）
  .rounded-4.overflow-hidden.shadow.mb-4{style: "background: linear-gradient(135deg, #{color} 0%, #{sub_color} 100%);"}
    .p-5
      %h1.fw-bold.mb-1{style: 'color: rgba(255,255,255,0.95); text-shadow: 0 1px 4px rgba(0,0,0,0.3);'}
        = @store.name
      .d-flex.flex-wrap.gap-3.mt-2{style: 'color: rgba(255,255,255,0.8);'}
        %span
          %i.fas.fa-tag.me-1
          = @store.store_category&.name
        %span
          %i.fas.fa-map-marker-alt.me-1
          = @store.town.name
        %span
          %i.fas.fa-user.me-1
          = @store.user&.name

  / 出品中の商品
  .card.border-0.shadow-sm.overflow-hidden
    .card-header.fw-bold.py-3{style: "background: linear-gradient(90deg, #{color}22 0%, transparent 100%); border-left: 4px solid #{color};"}
      %i.fas.fa-shopping-bag.me-2{style: "color: #{color};"}
      出品中の商品
    .card-body.p-0
      - if @listed_stocks.any?
        .table-responsive
          %table.table.table-hover.align-middle.mb-0
            %thead{style: "background: #{color}11;"}
              %tr
                %th.ps-4 商品名
                %th カテゴリ
                %th.text-end 価格
                %th
            %tbody
              - @listed_stocks.each do |stock|
                %tr
                  %td.ps-4.fw-bold= stock.name
                  %td.text-muted.small= stock.item_sub_category&.name
                  %td.text-end.fw-bold= "#{number_with_delimiter(stock.price)}円"
                  %td.text-end.pe-3
                    - unless @is_owner
                      = link_to '購入する', purchase_store_store_actions_path(stock_id: stock.id),
                          class: 'btn btn-sm fw-bold',
                          style: "background: #{color}; color: #fff; border: none;"
      - else
        .p-4.text-muted 現在出品中の商品はありません。
